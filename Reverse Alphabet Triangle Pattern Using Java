import java.util.Scanner;
public class Main
{
	public static void main(String[] args) {
	    Scanner sc=new Scanner(System.in);
	    int a=sc.nextInt();
	    
	    for(int row=0;row<a;row++){
	        for(int col=a;col>row;col--){
	            System.out.print((char)('E' - row)+ " ");
	        }
	        
	        System.out.println( );
	    }
	    
		
	}
}

